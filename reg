<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes, maximum-scale=2.0, minimum-scale=0.5">
  <title>Пирамикс • 5 уровней рефералов</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      background: linear-gradient(145deg, #0b0c0e 0%, #1a1c22 100%);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding: 20px;
      margin: 0;
      position: relative;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      top: -30%;
      left: -10%;
      width: 70%;
      height: 70%;
      background: radial-gradient(circle at 30% 30%, rgba(180, 130, 255, 0.08), transparent 60%);
      border-radius: 50%;
      z-index: 0;
      pointer-events: none;
    }

    /* Верхний контент: форма + статистика + график */
    .top-content {
      width: 100%;
      max-width: 1300px;
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: flex-start;
      justify-content: center;
      gap: 2rem;
      position: relative;
      z-index: 2;
      margin-bottom: 30px;
    }

    .form-wrapper {
      flex: 0 0 340px;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }

    .auth-card {
      background: rgba(20, 22, 27, 0.9);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(255, 215, 150, 0.18);
      border-radius: 2.5rem;
      padding: 2rem 2rem 1.8rem;
      width: 100%;
      max-width: 360px;
      box-shadow: 0 30px 50px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(255, 200, 100, 0.15);
      color: #f5efe0;
      transition: all 0.3s ease;
      animation: slideFromTopRight 0.9s cubic-bezier(0.22, 0.98, 0.41, 1.1) forwards;
      transform-origin: top right;
      margin-top: 10px;
    }

    @keyframes slideFromTopRight {
      0% { opacity: 0; transform: translate(60px, -160px) scale(0.92); }
      30% { opacity: 0.9; transform: translate(30px, -40px) scale(0.98); }
      70% { opacity: 1; transform: translate(8px, 5px) scale(1.01); }
      100% { opacity: 1; transform: translate(0, 0) scale(1); }
    }

    .auth-card h3 {
      font-size: 1.7rem;
      font-weight: 600;
      margin-bottom: 1.8rem;
      letter-spacing: -0.3px;
      background: linear-gradient(135deg, #f9d56e, #e6a861);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: inline-block;
    }

    .input-group {
      margin-bottom: 1.4rem;
    }

    .input-group label {
      display: block;
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.4px;
      color: #b9b09a;
      margin-bottom: 0.3rem;
      text-transform: uppercase;
    }

    .input-group input {
      width: 100%;
      background: rgba(15, 16, 20, 0.8);
      border: 1px solid rgba(220, 180, 100, 0.25);
      border-radius: 1.2rem;
      padding: 0.9rem 1.2rem;
      font-size: 1rem;
      color: #f5e7cc;
      outline: none;
      transition: all 0.25s;
      font-family: 'Inter', sans-serif;
      backdrop-filter: blur(4px);
    }

    .input-group input:focus {
      border-color: #f3b95b;
      box-shadow: 0 0 14px rgba(243, 185, 91, 0.4);
      background: rgba(22, 22, 28, 0.9);
    }

    .input-group input::placeholder {
      color: #5e5a4f;
      font-weight: 400;
      font-size: 0.9rem;
    }

    .password-field {
      transition: all 0.35s ease;
      overflow: hidden;
    }

    .hidden-password {
      max-height: 0;
      opacity: 0;
      margin-bottom: 0;
      pointer-events: none;
      transform: translateY(-8px);
    }

    .visible-password {
      max-height: 80px;
      opacity: 1;
      margin-bottom: 1.4rem;
      transform: translateY(0);
    }

    .action-btn {
      background: linear-gradient(135deg, #e2a542, #c7851e);
      border: none;
      color: #0f0e0a;
      font-weight: 700;
      font-size: 1rem;
      padding: 0.8rem 1.8rem;
      border-radius: 2.5rem;
      cursor: pointer;
      backdrop-filter: blur(8px);
      transition: 0.25s;
      margin-top: 0.2rem;
      margin-bottom: 0.8rem;
      letter-spacing: 0.5px;
      display: inline-block;
      box-shadow: 0 8px 18px rgba(226, 165, 66, 0.35);
      width: auto;
      min-width: 180px;
    }

    .action-btn:hover {
      background: linear-gradient(135deg, #f3b95b, #da9729);
      box-shadow: 0 10px 24px rgba(243, 185, 91, 0.6);
      color: #000;
    }

    .switch-text {
      font-size: 0.85rem;
      color: #b9b09a;
      margin-top: 0.5rem;
      display: block;
    }

    .switch-text span {
      color: #f3b95b;
      font-weight: 600;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
      margin-left: 4px;
    }

    .switch-text span:hover {
      color: #ffd966;
    }

    /* Боковая панель статистики */
    .stats-panel {
      flex: 0 0 260px;
      background: rgba(20, 22, 27, 0.8);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: 2rem;
      padding: 1.8rem 1.5rem;
      border: 1px solid rgba(255, 215, 150, 0.2);
      color: #f5efe0;
      box-shadow: 0 20px 35px rgba(0,0,0,0.7);
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
    }

    .stat-item {
      background: rgba(0,0,0,0.3);
      border-radius: 1.2rem;
      padding: 1rem;
      text-align: center;
    }

    .stat-label {
      font-size: 0.8rem;
      color: #b9b09a;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.4rem;
    }

    .stat-value {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(135deg, #fad974, #ebaa5e);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      transition: all 0.2s;
    }

    /* Правая секция с графиком */
    .info-section {
      flex: 1 1 400px;
      background: rgba(12, 14, 18, 0.65);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-radius: 2.8rem;
      padding: 2.2rem 2rem;
      border: 1px solid rgba(230, 180, 70, 0.2);
      box-shadow: 0 25px 45px rgba(0,0,0,0.8);
      color: #ece3d5;
      animation: fadeInInfo 1s ease-out;
    }

    @keyframes fadeInInfo {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .info-section h2 {
      font-size: 2.2rem;
      font-weight: 700;
      margin-bottom: 0.4rem;
      background: linear-gradient(to right, #fad974, #ebaa5e);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: -0.5px;
    }

    .subtitle {
      color: #b7a16c;
      font-weight: 500;
      margin-bottom: 2rem;
      font-size: 1rem;
      border-left: 3px solid #e3a94d;
      padding-left: 1rem;
    }

    .chart-container {
      margin: 1.8rem 0 2rem;
    }

    .chart-bars {
      display: flex;
      align-items: flex-end;
      justify-content: space-around;
      height: 180px;
      padding: 0 0.4rem;
      border-bottom: 2px solid rgba(230, 180, 70, 0.4);
      margin-bottom: 0.8rem;
    }

    .bar-wrapper {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 70px;
    }

    .bar {
      width: 40px;
      background: linear-gradient(180deg, #f3b95b, #d18e2c);
      border-radius: 20px 20px 6px 6px;
      box-shadow: 0 -5px 15px rgba(243, 185, 91, 0.5);
      margin-bottom: 6px;
    }

    .bar-percent {
      font-weight: 700;
      font-size: 1.1rem;
      color: #efc468;
      margin-bottom: 4px;
    }

    .bar-label {
      font-weight: 600;
      font-size: 1rem;
      color: #f5d78c;
      margin-top: 4px;
    }

    .legend {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 0.4rem;
      color: #cfbc8b;
      font-size: 0.9rem;
    }

    .legend span::before {
      content: "●";
      margin-right: 6px;
      color: #f3b95b;
      font-size: 1rem;
    }

    .graph-note {
      margin-top: 1.5rem;
      font-size: 0.95rem;
      color: #c9ad7a;
      text-align: center;
      border-top: 1px dashed #b49450;
      padding-top: 1.2rem;
    }

    /* Нижняя лента транзакций */
    .live-feed {
      width: 100%;
      max-width: 1300px;
      background: rgba(10, 12, 15, 0.8);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border-radius: 2rem;
      border: 1px solid rgba(230, 180, 70, 0.25);
      padding: 1.2rem 1.5rem;
      display: flex;
      gap: 1.5rem;
      z-index: 3;
      box-shadow: 0 -10px 30px rgba(0,0,0,0.7);
      margin-top: 10px;
    }

    .feed-half {
      flex: 1;
      min-width: 0;
    }

    .feed-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #c9ad7a;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.8rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .feed-list {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      height: 220px;
      overflow: hidden;
      position: relative;
    }

    .feed-item {
      background: rgba(25, 22, 17, 0.6);
      border-radius: 1rem;
      padding: 0.5rem 1rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.85rem;
      border: 1px solid rgba(212, 165, 60, 0.2);
      animation: fadeInUp 0.4s ease-out;
      transition: all 0.2s;
    }

    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(15px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .feed-user {
      font-weight: 600;
      color: #f5d78c;
    }

    .feed-time {
      color: #8b8a7a;
      font-size: 0.7rem;
      margin-left: 0.5rem;
    }

    .feed-amount {
      font-weight: 700;
      color: #efc468;
    }

    .deposit .feed-amount { color: #4caf50; }
    .withdraw .feed-amount { color: #ff7043; }

    @media (max-width: 900px) {
      .live-feed {
        flex-direction: column;
      }
      .feed-list {
        height: 160px;
      }
    }
  </style>
</head>
<body>
<div class="top-content">
  <!-- Левая форма -->
  <div class="form-wrapper">
    <div class="auth-card" id="authCard">
      <h3>✨ Пирамикс</h3>

      <div class="input-group">
        <label>Никнейм</label>
        <input type="text" id="nickname" placeholder="Введите ник" autocomplete="off">
      </div>

      <div class="input-group" id="password1Group">
        <label>Пароль</label>
        <input type="password" id="password1" placeholder="••••••••">
      </div>

      <div class="input-group visible-password" id="password2Group">
        <label>Повторите пароль</label>
        <input type="password" id="password2" placeholder="••••••••">
      </div>

      <button class="action-btn" id="actionButton">Зарегистрироваться</button>
      <div class="switch-text" id="switchTextBlock">
        Если есть аккаунт, <span id="toggleModeLink">вход</span>
      </div>
    </div>
  </div>

  <!-- Боковая статистика -->
  <div class="stats-panel">
    <div class="stat-item">
      <div class="stat-label">👥 Всего пользователей</div>
      <div class="stat-value" id="totalUsers">24344</div>
    </div>
    <div class="stat-item">
      <div class="stat-label">📅 Сегодня зарегистрировано</div>
      <div class="stat-value" id="todayUsers">127</div>
    </div>
    <div class="stat-item">
      <div class="stat-label">💰 Всего вывели денег</div>
      <div class="stat-value" id="totalWithdrawn">18500 $</div>
    </div>
  </div>

  <!-- Правая часть: график -->
  <div class="info-section">
    <h2>5 линий рефералов</h2>
    <div class="subtitle">Ваш доход растёт с каждым уровнем</div>

    <div class="chart-container">
      <div class="chart-bars">
        <div class="bar-wrapper"><span class="bar-percent">1%</span><div class="bar" style="height: 30px;"></div><span class="bar-label">1 ур.</span></div>
        <div class="bar-wrapper"><span class="bar-percent">2%</span><div class="bar" style="height: 55px;"></div><span class="bar-label">2 ур.</span></div>
        <div class="bar-wrapper"><span class="bar-percent">3%</span><div class="bar" style="height: 80px;"></div><span class="bar-label">3 ур.</span></div>
        <div class="bar-wrapper"><span class="bar-percent">4%</span><div class="bar" style="height: 105px;"></div><span class="bar-label">4 ур.</span></div>
        <div class="bar-wrapper"><span class="bar-percent">5%</span><div class="bar" style="height: 130px;"></div><span class="bar-label">5 ур.</span></div>
      </div>
      <div class="legend"><span>Процент от дохода рефералов</span></div>
    </div>
    <div class="graph-note">📊 Чем глубже уровень — тем выше процент. <br> Приглашайте активных партнёров и увеличивайте прибыль.</div>
  </div>
</div>

<!-- Нижняя лента транзакций -->
<div class="live-feed">
  <div class="feed-half deposit-feed">
    <div class="feed-title">🟢 Пополнения (10$)</div>
    <div class="feed-list" id="depositList"></div>
  </div>
  <div class="feed-half withdraw-feed">
    <div class="feed-title">🔴 Выводы (10$)</div>
    <div class="feed-list" id="withdrawList"></div>
  </div>
</div>

<script>
  (function() {
    // ---------- Форма ----------
    const password2Group = document.getElementById('password2Group');
    const actionButton = document.getElementById('actionButton');
    const toggleModeLink = document.getElementById('toggleModeLink');
    const switchTextBlock = document.getElementById('switchTextBlock');
    let isLoginMode = false;

    function updateUIForMode() {
      if (isLoginMode) {
        password2Group.classList.remove('visible-password');
        password2Group.classList.add('hidden-password');
        actionButton.textContent = 'Войти';
        switchTextBlock.innerHTML = 'Нет аккаунта? <span id="toggleModeLink">Зарегистрироваться</span>';
        document.getElementById('toggleModeLink').addEventListener('click', switchToRegister);
      } else {
        password2Group.classList.remove('hidden-password');
        password2Group.classList.add('visible-password');
        actionButton.textContent = 'Зарегистрироваться';
        switchTextBlock.innerHTML = 'Если есть аккаунт, <span id="toggleModeLink">вход</span>';
        document.getElementById('toggleModeLink').addEventListener('click', switchToLogin);
      }
    }

    function switchToLogin() { isLoginMode = true; updateUIForMode(); }
    function switchToRegister() { isLoginMode = false; updateUIForMode(); }
    updateUIForMode();

    actionButton.addEventListener('click', function(e) {
      e.preventDefault();
      const nickname = document.getElementById('nickname').value.trim();
      const password1 = document.getElementById('password1').value;
      if (!nickname) { alert('Пожалуйста, введите никнейм.'); return; }
      if (!password1) { alert('Введите пароль.'); return; }

      if (isLoginMode) {
        // Сохраняем в localStorage и переходим на home
        localStorage.setItem('pirxmix_user', JSON.stringify({ nickname, password: password1 }));
        window.location.href = 'https://vds-game.ink/home';
      } else {
        const password2 = document.getElementById('password2').value;
        if (password1 !== password2) { alert('Пароли не совпадают.'); return; }
        localStorage.setItem('pirxmix_user', JSON.stringify({ nickname, password: password1 }));
        window.location.href = 'https://vds-game.ink/home';
      }
    });

    document.getElementById('authCard').addEventListener('submit', (e) => e.preventDefault());

    // ---------- Счётчики ----------
    let totalUsers = 24344;
    let todayUsers = 127;
    const totalUsersEl = document.getElementById('totalUsers');
    const todayUsersEl = document.getElementById('todayUsers');

    function animateValue(element, start, end, duration = 600) {
      if (start === end) return;
      const range = end - start;
      const increment = range > 0 ? 1 : -1;
      const stepTime = Math.abs(Math.floor(duration / range));
      let current = start;
      const timer = setInterval(() => {
        current += increment;
        element.textContent = current;
        if (current === end) clearInterval(timer);
      }, stepTime);
    }

    function incrementUsers() {
      const oldTotal = totalUsers;
      totalUsers++;
      todayUsers++;
      animateValue(totalUsersEl, oldTotal, totalUsers, 400);
      animateValue(todayUsersEl, todayUsers - 1, todayUsers, 400);
    }

    // Каждые 3-7 секунд +1 пользователь
    function scheduleNextIncrement() {
      const delay = Math.floor(Math.random() * 4000) + 3000; // 3000-7000 мс
      setTimeout(() => {
        incrementUsers();
        scheduleNextIncrement();
      }, delay);
    }
    scheduleNextIncrement();

    // Сброс сегодняшних в 00:00
    function scheduleMidnightReset() {
      const now = new Date();
      const midnight = new Date(now);
      midnight.setHours(24, 0, 0, 0);
      const msToMidnight = midnight - now;
      setTimeout(() => {
        todayUsers = 0;
        todayUsersEl.textContent = '0';
        scheduleMidnightReset();
      }, msToMidnight);
    }
    scheduleMidnightReset();

    // ---------- Лента транзакций ----------
    const depositList = document.getElementById('depositList');
    const withdrawList = document.getElementById('withdrawList');
    const MAX_ITEMS = 10;

    const firstNames = ['Alex', 'Mira', 'Jon', 'Lena', 'Max', 'Sara', 'Tom', 'Anna', 'Leo', 'Kate'];
    const lastNames = ['Gold', 'Fox', 'Star', 'Moon', 'Wolf', 'Sky', 'Rose', 'Hill', 'Byte', 'Coin'];

    function randomNick() {
      return firstNames[Math.floor(Math.random() * firstNames.length)] + 
             lastNames[Math.floor(Math.random() * lastNames.length)] + 
             Math.floor(Math.random() * 100);
    }

    function getCurrentTime() {
      const d = new Date();
      return d.toLocaleTimeString('ru-RU', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }

    function addTransaction(container, type) {
      const item = document.createElement('div');
      item.className = `feed-item ${type}`;
      const nick = randomNick();
      const time = getCurrentTime();
      item.innerHTML = `<span><span class="feed-user">${nick}</span><span class="feed-time">${time}</span></span><span class="feed-amount">10$</span>`;
      
      container.prepend(item);
      
      // Удаляем лишние элементы
      while (container.children.length > MAX_ITEMS) {
        container.removeChild(container.lastChild);
      }
    }

    // Генерируем начальные 10 записей
    for (let i = 0; i < MAX_ITEMS; i++) {
      addTransaction(depositList, 'deposit');
      addTransaction(withdrawList, 'withdraw');
    }

    // Каждые 2-5 секунд новая транзакция
    function randomTransaction() {
      const type = Math.random() < 0.5 ? 'deposit' : 'withdraw';
      const container = type === 'deposit' ? depositList : withdrawList;
      addTransaction(container, type);
      
      const nextDelay = Math.floor(Math.random() * 3000) + 2000;
      setTimeout(randomTransaction, nextDelay);
    }
    setTimeout(randomTransaction, 2000);

  })();
</script>
</body>
</html>
