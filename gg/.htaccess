<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
    Header set X-Frame-Options "ALLOW-FROM https://web.telegram.org"
    Header set Content-Security-Policy "frame-ancestors https://web.telegram.org https://telegram.org tg: *"
</IfModule>

# Убираем X-Frame-Options если есть
Header always unset X-Frame-Options
